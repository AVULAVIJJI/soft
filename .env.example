# ============================================================
# SOFTMASTER Enterprise Platform - Environment Variables
# Copy this file to .env and fill all values before running
# ============================================================

# Application
APP_NAME=Softmaster Technology Solutions
APP_ENV=development
APP_DEBUG=false
APP_URL=https://softmastertech.com
API_URL=https://api.softmastertech.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://softmaster_user:CHANGE_THIS_PASSWORD@localhost:5432/softmaster_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=softmaster_db
DB_USER=softmaster_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT Authentication
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Frontend URLs
NEXT_PUBLIC_API_URL=https://api.softmastertech.com
NEXT_PUBLIC_APP_URL=https://softmastertech.com
NEXT_PUBLIC_ACADEMY_URL=https://academy.softmastertech.com
NEXT_PUBLIC_JOBS_URL=https://jobs.softmastertech.com
NEXT_PUBLIC_ADMIN_URL=https://admin.softmastertech.com
NEXT_PUBLIC_CLIENT_URL=https://client.softmastertech.com
NEXT_PUBLIC_WORKSPACE_URL=https://workspace.softmastertech.com

# Cloudinary (Free tier - https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Email - Brevo (Free: 300 emails/day - https://brevo.com)
BREVO_API_KEY=your_brevo_api_key
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASSWORD=your_brevo_smtp_password
EMAIL_FROM=noreply@softmastertech.com
EMAIL_FROM_NAME=Softmaster Technology Solutions

# Payments - Razorpay (https://razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Redis (Optional - for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Admin Account (created on first run)
SUPER_ADMIN_EMAIL=admin@softmastertech.com
SUPER_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
SUPER_ADMIN_NAME=Softmaster Admin

# Security
ALLOWED_HOSTS=softmastertech.com,api.softmastertech.com,localhost
CORS_ORIGINS=https://softmastertech.com,https://academy.softmastertech.com,https://jobs.softmastertech.com,https://admin.softmastertech.com,https://client.softmastertech.com,https://workspace.softmastertech.com
SECRET_KEY=CHANGE_THIS_SECRET_KEY_FOR_ENCRYPTION

# Company Info
COMPANY_NAME=Softmaster Technology Solutions Pvt Ltd
COMPANY_ADDRESS=No:07, George E De Silva Mawatha, Kandy 20000, Sri Lanka
COMPANY_PHONE=+94812204130
COMPANY_EMAIL=info@softmastergroup.com
COMPANY_WEBSITE=https://softmastertech.com
