{
  "name": "softmaster-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Softmaster Technology Solutions Pvt Ltd - Enterprise SaaS Platform",
  "workspaces": [
    "frontend/apps/*",
    "frontend/components",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:website": "turbo run dev --filter=website",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:academy": "turbo run dev --filter=academy",
    "dev:jobs": "turbo run dev --filter=jobs",
    "dev:client": "turbo run dev --filter=client",
    "dev:workspace": "turbo run dev --filter=workspace",
    "build:website": "turbo run build --filter=website",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
